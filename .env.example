NODE_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=3000
# ADMIN_API_TOKEN=replace_with_long_random_token
# MAX_BRIDGE_TOKEN=replace_with_bridge_token
DELIVERY_BASE_BACKOFF_MS=5000
DELIVERY_MAX_BACKOFF_MS=300000
DELIVERY_LOCK_TIMEOUT_MS=300000
DELIVERY_MAX_ATTEMPTS=5
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_WORKER_POLL_MS=3000
TELEGRAM_BATCH_SIZE=3
# WEB_PUSH_PUBLIC_KEY=your_public_vapid_key_here
# WEB_PUSH_PRIVATE_KEY=your_private_vapid_key_here
# WEB_PUSH_SUBJECT=mailto:you@example.com
WEB_PUSH_WORKER_POLL_MS=5000
WEB_PUSH_BATCH_SIZE=3
LOG_LEVEL=info
# Relative paths are resolved from the project root.
DATABASE_PATH=./data/project-max.sqlite
