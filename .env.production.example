NODE_ENV=production
BACKEND_HOST=127.0.0.1
BACKEND_PORT=3000

# Protect admin and bridge endpoints with long random tokens.
ADMIN_API_TOKEN=replace_with_long_random_admin_token
MAX_BRIDGE_TOKEN=replace_with_long_random_bridge_token

# Main SQLite database path on Raspberry Pi.
DATABASE_PATH=/opt/project-max/data/project-max.sqlite

DELIVERY_BASE_BACKOFF_MS=5000
DELIVERY_MAX_BACKOFF_MS=300000
DELIVERY_LOCK_TIMEOUT_MS=300000
DELIVERY_MAX_ATTEMPTS=5

# Telegram delivery.
TELEGRAM_BOT_TOKEN=replace_with_bot_token
TELEGRAM_CHAT_ID=replace_with_chat_id
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_WORKER_POLL_MS=3000
TELEGRAM_BATCH_SIZE=3

# Web push delivery.
WEB_PUSH_PUBLIC_KEY=replace_with_vapid_public_key
WEB_PUSH_PRIVATE_KEY=replace_with_vapid_private_key
WEB_PUSH_SUBJECT=mailto:you@example.com
WEB_PUSH_WORKER_POLL_MS=5000
WEB_PUSH_BATCH_SIZE=3

LOG_LEVEL=info
